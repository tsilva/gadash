NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_AUTHORIZED_ORIGINS=http://localhost:3000,https://dash.example.com
NEXT_PUBLIC_SITE_URL=https://dash.example.com
# Required in production. Local development falls back to an ephemeral process-local secret when unset.
AUTH_SESSION_SECRET=replace-with-a-long-random-secret
ALLOWED_GOOGLE_EMAILS=eng.tiago.silva@gmail.com
NEXT_PUBLIC_GITHUB_CLIENT_ID=your-github-oauth-client-id
NEXT_PUBLIC_GITHUB_AUTHORIZED_ORIGINS=http://localhost:3000,https://dash.example.com
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
NEXT_PUBLIC_SENTRY_DSN=
# Optional server-side DSN override. Falls back to NEXT_PUBLIC_SENTRY_DSN when empty.
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=tsilva
SENTRY_PROJECT=gadash
SENTRY_BASE_URL=https://sentry.io
# Optional overrides. Defaults to 1.0 in development and 0.1 otherwise.
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=
SENTRY_TRACES_SAMPLE_RATE=
# Optional header value for GET /api/sentry/smoke
SENTRY_SMOKE_TEST_TOKEN=
# Optional fallback if auto-discovery is unavailable.
NEXT_PUBLIC_GA_PROPERTIES_JSON=[{"id":"123456789","label":"Main Site","sortOrder":1},{"id":"987654321","label":"Docs","sortOrder":2}]
PAGESPEED_API_KEY=
PAGESPEED_MONITORED_URLS=https://example.com,https://docs.example.com/guides
